{
  "name": "mongolian-grammar-checker",
  "version": "1.5.0",
  "description": "Chrome extension for offline Mongolian (Cyrillic) spell/typo checking.",
  "type": "module",
  "scripts": {
    "icons:placeholder": "node generate-icons.mjs",
    "test": "node --test test/*.test.mjs",
    "build": "node build.mjs",
    "prepare-dist": "npm run build",
    "demo": "npm run build && node build-demo.mjs",
    "demo:serve": "npm run demo && python3 -m http.server -d demo 8000",
    "package": "npm run prepare-dist && node package-extension.mjs"
  },
  "keywords": [
    "mongolian",
    "spellcheck",
    "hunspell",
    "chrome-extension"
  ],
  "license": "MIT",
  "dependencies": {
    "hunspell-asm": "^4.0.2"
  },
  "devDependencies": {
    "esbuild": "^0.24.2"
  }
}
